<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="ownCloud Sync"
    Version="0.1.0"
    Manufacturer="ownCloud GmbH"
    UpgradeCode="D4E5F6A7-B8C9-4D0E-A1F2-B3C4D5E6F7A8"
    Scope="perUser"
    Compressed="yes"
    InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="ownCloud Sync" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="ProgramsFolder" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="ownCloud" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="ownCloud" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!-- GUI binary -->
      <Component Id="ocsync_exe" Guid="*">
        <File Id="ocsync_exe" Source="$(var.BinDir)\ocsync.exe" KeyPath="yes" />
      </Component>

      <!-- Autostart on login for current user (separate per-user component) -->
      <Component Id="AutostartEntry" Guid="*">
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="ownCloudSync"
          Value="[INSTALLFOLDER]ocsync.exe"
          Type="string"
          KeyPath="yes" />
      </Component>

      <!-- Start Menu shortcut (separate per-user component) -->
      <Component Id="StartMenuShortcutComp" Guid="*" Directory="ApplicationProgramsFolder">
        <Shortcut
          Id="StartMenuShortcut"
          Name="ownCloud Sync"
          Description="Sync files with your ownCloud server"
          Target="[INSTALLFOLDER]ocsync.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\ownCloud GmbH\ownCloud Sync"
          Name="StartMenuShortcut"
          Value="1"
          Type="integer"
          KeyPath="yes" />
      </Component>

      <!-- Daemon binary -->
      <Component Id="ocsyncd_exe" Guid="*">
        <File Id="ocsyncd_exe" Source="$(var.BinDir)\ocsyncd.exe" KeyPath="yes" />
      </Component>

      <!-- Overlay COM DLL. COM registration (ShellIconOverlayIdentifiers etc.)
           is performed by the DLL's own DllRegisterServer, not authored here. -->
      <Component Id="oc_overlay_dll" Guid="*">
        <File Id="oc_overlay_dll" Source="$(var.BinDir)\oc_overlay.dll" KeyPath="yes" />
      </Component>

      <!-- Context menu COM DLL. COM registration (ContextMenuHandlers etc.) is
           performed by the DLL's own DllRegisterServer, not authored here. -->
      <Component Id="oc_contextmenu_dll" Guid="*">
        <File Id="oc_contextmenu_dll" Source="$(var.BinDir)\oc_contextmenu.dll" KeyPath="yes" />
      </Component>

      <!-- IPC helper DLL -->
      <Component Id="oc_ipc_dll" Guid="*">
        <File Id="oc_ipc_dll" Source="$(var.BinDir)\oc_ipc.dll" KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
